# —— 通用：所有包管理器都能用的标准 key ——
registry=https://registry.npmmirror.com/
save-prefix=^

# —— pnpm 专属配置 ——
# 注意：npm 不识别下列 key，会输出 warning，但不影响功能。
# 如果你只想让 npm 干净，没有这些警告：把下面的整段移到全局 ~/.npmrc 里，
# 或者直接放在 pnpm-workspace.yaml 的 settings 里也可以。
strict-peer-dependencies=true
auto-install-peers=true
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# —— 二进制下载镜像（环境变量形式，pnpm/npm 会注入到子进程） ——
# 当前依赖未使用 electron/sharp/puppeteer，可保留备用，也可删除
ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/
SASS_BINARY_SITE=https://npmmirror.com/mirrors/node-sass/
SHARP_BINARY_HOST=https://npmmirror.com/mirrors/sharp
SHARP_LIBVIPS_BINARY_HOST=https://npmmirror.com/mirrors/sharp-libvips
PUPPETEER_DOWNLOAD_BASE_URL=https://npmmirror.com/mirrors/chromium-browser-snapshots
PYTHON_MIRROR=https://npmmirror.com/mirrors/python/

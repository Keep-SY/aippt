# 前端环境变量示例 —— 复制为 .env.local 后再填写
# .env.local 已在 .gitignore 中，绝不提交

# ====== 推荐：后端代理模式（生产同样架构）======
# 由 server/ 持有 API Key，浏览器只与本地 FastAPI 通信
VITE_ARK_BASE_URL=/api/ai
VITE_ARK_MODEL=doubao-seed-1-6-251015
# 后端模式下 VITE_ARK_API_KEY 留空即可

# ====== 备用：浏览器直连（仅本地原型，Key 暴露在前端）======
# VITE_ARK_BASE_URL=/ark
# VITE_ARK_API_KEY=
# VITE_ARK_MODEL=doubao-seed-1-6-251015

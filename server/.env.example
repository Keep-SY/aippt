# 必填：火山引擎方舟 API Key
# 控制台 → 方舟模型服务 → API Key 管理
ARK_API_KEY=

# 选填：默认模型（前端不传 model 时使用）
# 例如：doubao-1-5-pro-32k-250115、doubao-seed-1-6-250615、ep-xxxxxxxx
ARK_DEFAULT_MODEL=doubao-1-5-pro-32k-250115

# 选填：ARK base url
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 选填：允许的前端来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 选填：上游请求超时秒数
REQUEST_TIMEOUT_SECONDS=120
